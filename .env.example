# ============================================================
#  EVEOps - Release Credentials
#  Copy this file to .env and fill in your values
#  .env is in .gitignore and will never be committed
#  App-specific password is stored in macOS Keychain via:
#    xcrun notarytool store-credentials "EVEOpsRelease" \
#      --apple-id "your@email.com" --team-id "XXXXXXXXXX"
# ============================================================

# Your Apple ID email
APPLE_ID=your@email.com

# 10-character Team ID from https://developer.apple.com/account
# Membership Details -> Team ID
TEAM_ID=XXXXXXXXXX
