<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
	<!-- Required for EVEInstallLocator: persist security-scoped bookmark to EVE SharedCache across launches -->
	<key>com.apple.security.files.bookmarks.app-scope</key>
	<true/>
	<!-- Sparkle: Installer Connection (-spki) and Status (-spks) IPC channels -->
	<key>com.apple.security.temporary-exception.mach-lookup.global-name</key>
	<array>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)-spki</string>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)-spks</string>
	</array>
	<!-- Sparkle: allow reading/writing its own preferences domain -->
	<key>com.apple.security.temporary-exception.shared-preference.read-write</key>
	<array>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	</array>
</dict>
</plist>
